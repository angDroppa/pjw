generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"

}

// ==========================================
// ENUMS
// ==========================================

enum TipologiaBicicletta {
  CITY
  MOUNTAIN
  GRAVEL
  ROAD
}

enum Alimentazione {
  MUSCOLARE
  ELETTRICA
}

enum StatoPrenotazione {
  PENDING
  PICKED_UP
  RETURNED
  LATE
}

// ==========================================
// UTENTI E AUTENTICAZIONE
// ==========================================

model Role {
  role  String @id
  users User[]

}

model User {
  id                Int            @id @default(autoincrement())
  firstName         String
  lastName          String
  email             String         @unique
  password          String
  verified          Boolean        @default(false)
  verificationToken String?
  roleName          String
  role              Role           @relation(fields: [roleName], references: [role])
  notifiche         Notifica[]
  prenotazioni      Prenotazione[]
  refreshTokens     RefreshToken[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notifica {
  id        Int      @id @default(autoincrement())
  messaggio String
  tipo      String   @default("generica")
  sentAt    DateTime @default(now())
  letto     Boolean  @default(false)
  utenteId  Int
  utente    User     @relation(fields: [utenteId], references: [id])
}

// ==========================================
// PRENOTAZIONI
// ==========================================

model Prenotazione {
  id           Int      @id @default(autoincrement())
  dataCreazione DateTime @default(now())
  dataRitiro   DateTime @db.Date
  oraRitiro    String
  dataConsegna DateTime
  oraConsegna  String

  stato        StatoPrenotazione @default(PENDING)
  note         String?
  noteRiconsegna String?
  danni        String?
  totalePagato Decimal           @db.Decimal(10, 2)

  utenteId Int
  utente   User @relation(fields: [utenteId], references: [id], onDelete: Cascade)

  biciclettaId    Int
  bicicletta      SpecificheBicicletta @relation(fields: [biciclettaId], references: [id], onDelete: Cascade)

  biciclettaIstanzaId Int?
  biciclettaIstanza   BiciclettaIstanza? @relation(fields: [biciclettaIstanzaId], references: [id], onDelete: SetNull)

  locationId Int
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  coperturaId Int
  copertura   Assicurazione @relation(fields: [coperturaId], references: [id], onDelete: Cascade)

  prenotazioni AccessorioPrenotazione[]
}

model Accessorio {
  id           Int                      @id @default(autoincrement())
  nome         String
  prezzo       Float                    @default(0.0)
  prenotazioni AccessorioPrenotazione[]

}

model AccessorioPrenotazione {
  id             Int          @id @default(autoincrement())
  accessorioId   Int
  prenotazioneId Int
  accessorio     Accessorio   @relation(fields: [accessorioId], references: [id], onDelete: Cascade)
  prenotazione   Prenotazione @relation(fields: [prenotazioneId], references: [id], onDelete: Cascade)
}

model Assicurazione {
  id           Int            @id @default(autoincrement())
  tipo         String
  dettagli     String
  prezzo       Decimal        @default(0.0)
  prenotazioni Prenotazione[]
}

// ==========================================
// LOCATION
// ==========================================

model Location {
  id        Int    @id @default(autoincrement())
  nome      String
  indirizzo String

  biciclette   BiciclettaLocation[]
  istanze      BiciclettaIstanza[]
  prenotazioni Prenotazione[]
}

model BiciclettaLocation {
  id                     Int                   @id @default(autoincrement())
  locationId             Int
  biciclettaSpecificId   Int
  quantita               Int                   @default(0)
  location               Location              @relation(fields: [locationId], references: [id], onDelete: Cascade)
  biciclettaSpecific     SpecificheBicicletta  @relation(fields: [biciclettaSpecificId], references: [id], onDelete: Cascade)
  istanze                BiciclettaIstanza[]
  @@unique([locationId, biciclettaSpecificId])
}

model BiciclettaIstanza {
  id                      Int                     @id @default(autoincrement())
  codice                  String
  specificheBiciclettaId  Int
  locationId              Int
  occupata                Boolean                 @default(false)
  occupataDa              DateTime?
  occupataA               DateTime?

  biciclettaLocationId    Int?
  biciclettaLocation      BiciclettaLocation?    @relation(fields: [biciclettaLocationId], references: [id], onDelete: SetNull)
  specificheBicicletta    SpecificheBicicletta   @relation(fields: [specificheBiciclettaId], references: [id])
  location                Location               @relation(fields: [locationId], references: [id])
  prenotazioni            Prenotazione[]

  @@unique([codice])
}

// ==========================================
// BICICLETTE E SPECIFICHE
// ==========================================

model Bicicletta {
  id        Int        @id @default(autoincrement())
  nome      String
  tipologia TipologiaBicicletta
  specifics SpecificheBicicletta[]
}

model SpecificheBicicletta {
  id                  Int                   @id @default(autoincrement())
  size                String
  alimentazione        Alimentazione
  prezzoGiornata       Decimal               @db.Decimal(10, 2)
  prezzoMezzaGiornata  Decimal               @db.Decimal(10, 2)
  altezzaMin           Int?
  altezzaMax           Int?
  biciclettaId         Int
  bicicletta           Bicicletta            @relation(fields: [biciclettaId], references: [id])
  prenotazione         Prenotazione[]
  location             BiciclettaLocation[]
  istanze              BiciclettaIstanza[]
  @@unique([biciclettaId, size, alimentazione])
}
