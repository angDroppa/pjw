generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  role  String @id
  users User[]
}

model User {
  id            Int            @id @default(autoincrement())
  firstName     String
  lastName      String
  email         String         @unique
  password      String
  roleName      String
  notifiche     Notifica[]
  prenotazioni  Prenotazione[]
  refreshTokens RefreshToken[]
  role          Role           @relation(fields: [roleName], references: [role])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bicicletta {
  id          Int       @id @default(autoincrement())
  modelloId   Int
  modello     Modello   @relation(fields: [modelloId], references: [id])

  // CAMBIAMENTO QUI: Relazione molti-a-molti implicita (diventa un array)
  tipologie   Tipologia[] 

  dimensioni   Dimensione[]
  prenotazioni Prenotazione[]

}

model Modello {
  id         Int          @id @default(autoincrement())
  nome       String
  biciclette Bicicletta[]
}

model Tipologia {
  id         Int          @id @default(autoincrement())
  nome       String // Esempi: "Elettrica", "Muscolare", "Mountain Bike"
  biciclette Bicicletta[] // Relazione molti-a-molti speculare
}

model Prenotazione {
  id              Int       @id @default(autoincrement())
  dataRitiro      DateTime
  dataOreConsegna DateTime
  dataPickUp      DateTime

  utenteId        Int
  utente          User       @relation(fields: [utenteId], references: [id], onDelete: Cascade)

  biciclettaId    Int
  bicicletta      Bicicletta @relation(fields: [biciclettaId], references: [id], onDelete: Cascade)

  locationId      Int
  location        Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)

  coperturaId     Int
  copertura       Assicurazione @relation(fields: [coperturaId], references: [id], onDelete: Cascade)

  accessori       Accessorio[]  
}

model Accessorio {
  id           Int            @id @default(autoincrement())
  nome         String
  prenotazioni Prenotazione[] 
}

model Assicurazione {
  id           Int            @id @default(autoincrement())
  tipo         String
  dettagli     String
  prenotazioni Prenotazione[] 
}

model Location {
  id           Int            @id @default(autoincrement())
  nome         String
  indirizzo    String
  prenotazioni Prenotazione[]
}

model Notifica {
  id        Int    @id @default(autoincrement())
  messaggio String
  utenteId  Int
  utente    User   @relation(fields: [utenteId], references: [id])
}

model Dimensione {
  id           Int        @id @default(autoincrement())
  biciclettaId Int  
  bicicletta   Bicicletta @relation(fields: [biciclettaId], references: [id], onDelete: Cascade)        

  taglia           String
  quantitaElettrico Int
  quantitaMuscolare Int
}