generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  role  String @id
  users User[]
}

model User {
  id        Int    @id @default(autoincrement())
  firstName String
  lastName  String
  email     String @unique
  password  String

  role     Role   @relation(fields: [roleName], references: [role])
  roleName String

  refreshTokens RefreshToken[]
  prenotazioni  Prenotazione[]
  notifiche     Notifica[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bicicletta {
  id         Int     @id @default(autoincrement())
  dimensione String

  modelloId   Int
  modello     Modello   @relation(fields: [modelloId], references: [id])

  tipologiaId Int
  tipologia   Tipologia @relation(fields: [tipologiaId], references: [id])

  accessori Accessorio[] // many-to-many implicito

  coperturaId Int
  copertura   Assicurazione @relation(fields: [coperturaId], references: [id], onDelete: Cascade)

  prenotazioni Prenotazione[]
}

model Modello {
  id         Int          @id @default(autoincrement())
  nome       String
  biciclette Bicicletta[]
}

model Tipologia {
  id         Int          @id @default(autoincrement())
  nome       String
  biciclette Bicicletta[]
}

model Accessorio {
  id         Int          @id @default(autoincrement())
  nome       String
  biciclette Bicicletta[]
}

model Assicurazione {
  id         Int          @id @default(autoincrement())
  tipo       String
  dettagli   String
  biciclette Bicicletta[]
}

model Prenotazione {
  id              Int        @id @default(autoincrement())
  dataRitiro      DateTime
  dataOreConsegna DateTime
  dataPickUp      DateTime

  utenteId     Int
  utente       User       @relation(fields: [utenteId], references: [id], onDelete: Cascade)

  biciclettaId Int
  bicicletta   Bicicletta @relation(fields: [biciclettaId], references: [id], onDelete: Cascade)

  locationId Int
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model Location {
  id           Int            @id @default(autoincrement())
  nome         String
  indirizzo    String
  prenotazioni Prenotazione[]
}

model Notifica {
  id        Int    @id @default(autoincrement())
  messaggio String
  utenteId  Int
  utente    User   @relation(fields: [utenteId], references: [id])
}

