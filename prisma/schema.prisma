
generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  role  String @id
  users User[]
}

model User {
  id        Int    @id @default(autoincrement())
  firstName String
  lastName  String
  email     String @unique
  password  String

  role     Role   @relation(fields: [roleName], references: [role])
  roleName String

  refreshTokens RefreshToken[]
  prenotazioni  Prenotazione[]
  notifiche     Notifica[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bicicletta {
  id           Int            @id @default(autoincrement())
  tipologia    String
  dimensione   String
  accessori    String
  coperturaId  Int
  copertura    Assicurazione  @relation(fields: [coperturaId], references: [id], onDelete: Cascade)
  prenotazioni Prenotazione[]
}

model Assicurazione {
  id         Int          @id @default(autoincrement())
  tipo       String
  dettagli   String
  biciclette Bicicletta[]
}

model Prenotazione {
  id              Int        @id @default(autoincrement())
  dataRitiro      DateTime
  dataOreConsegna DateTime
  dataPickUp      DateTime
  utenteId        Int
  biciclettaId    Int
  utente          User       @relation(fields: [utenteId], references: [id], onDelete: Cascade)
  bicicletta      Bicicletta @relation(fields: [biciclettaId], references: [id], onDelete: Cascade)
}

model Notifica {
  id        Int    @id @default(autoincrement())
  messaggio String
  utenteId  Int
  utente   User       @relation(fields: [utenteId], references: [id])
}


