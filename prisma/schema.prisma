generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// UTENTI E AUTENTICAZIONE
// ==========================================

model Role {
  role  String @id
  users User[]
}

model User {
  id            Int            @id @default(autoincrement())
  firstName     String
  lastName      String
  email         String         @unique
  password      String
  roleName      String
  role          Role           @relation(fields: [roleName], references: [role])
  notifiche     Notifica[]
  prenotazioni  Prenotazione[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notifica {
  id        Int    @id @default(autoincrement())
  messaggio String
  utenteId  Int
  utente    User   @relation(fields: [utenteId], references: [id])
}

// ==========================================
// CONFIGURAZIONE NEGOZI (LOCATION) & STOCK
// ==========================================

model Location {
  id                  Int               @id @default(autoincrement())
  nome                String
  indirizzo           String
  
  // Task 1: Listino prezzi base del punto vendita
  prezzoMezzaGiornata Float             @default(0.0)
  
  // Relazioni
  stocks              StockBicicletta[]
  prenotazioni        Prenotazione[]
}

// NUOVO MODELLO: Tabella pivot per lo Stock fisico per ogni negozio
model StockBicicletta {
  id             Int        @id @default(autoincrement())
  quantita       Int        @default(0) // Stock totale posseduto
  inManutenzione Int        @default(0) // Task 3: Bici bloccate in officina
  
  // Relazione con la Location (Negozio)
  locationId     Int
  location       Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  
  // Relazione con la Bicicletta
  biciclettaId   Int
  bicicletta     Bicicletta @relation(fields: [biciclettaId], references: [id], onDelete: Cascade)

  @@unique([locationId, biciclettaId]) // Evita duplicati dello stesso modello nello stesso negozio
}

// ==========================================
// CATALOGO BICICLETTE e VARIANTI
// ==========================================

model Bicicletta {
  id           Int               @id @default(autoincrement())
  modelloId    Int
  modello      Modello           @relation(fields: [modelloId], references: [id])
  
  tipologie    Tipologia[]       // Relazione molti-a-molti implicita
  dimensioni   Dimensione[]      // Relazione uno-a-molti con le taglie
  
  stocks       StockBicicletta[] // Relazione con gli stock dei negozi
  prenotazioni Prenotazione[]    // Relazione con lo storico prenotazioni
}

model Modello {
  id         Int          @id @default(autoincrement())
  nome       String
  biciclette Bicicletta[]
}

model Tipologia {
  id         Int          @id @default(autoincrement())
  nome       String       // Esempi: "Elettrica", "Muscolare", "Mountain Bike"
  biciclette Bicicletta[] // Relazione molti-a-molti speculare implicita
}

model Dimensione {
  id                Int        @id @default(autoincrement())
  taglia            String     // S, M, L, XL
  quantitaElettrico Int        @default(0)
  quantitaMuscolare Int        @default(0)
  
  biciclettaId      Int
  bicicletta        Bicicletta @relation(fields: [biciclettaId], references: [id], onDelete: Cascade)
}

// ==========================================
// PRENOTAZIONI E SERVIZI AGGIUNTIVI
// ==========================================

enum StatoPrenotazione {
  PENDING      // In attesa di ritiro
  PICKED_UP    // Check-in effettuato (Bici ritirata)
  RETURNED     // Check-in riconsegna effettuato
  LATE         // Segnalato Ritardo
  DAMAGED      // Segnalato Danno
  CANCELLED    // Annullata
}

model Prenotazione {
  id              Int               @id @default(autoincrement())
  dataRitiro      DateTime
  dataOreConsegna DateTime
  dataPickUp      DateTime          // Data effettiva in cui l'utente si presenta
  
  // Task 2 & 4: Stato operativo e tracciamento ricavi
  stato           StatoPrenotazione @default(PENDING)
  noteProblemi    String?           // Campo per descrivere danni o motivi del ritardo
  totalePagato    Float             @default(0.0)

  // Relazione Utente
  utenteId        Int
  utente          User              @relation(fields: [utenteId], references: [id], onDelete: Cascade)

  // Relazione Bicicletta
  biciclettaId    Int
  bicicletta      Bicicletta        @relation(fields: [biciclettaId], references: [id], onDelete: Cascade)

  // Relazione Location (Negozio in cui avviene il noleggio)
  locationId      Int
  location        Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)

  // Relazione Assicurazione (Una copertura per prenotazione)
  coperturaId     Int
  copertura       Assicurazione     @relation(fields: [coperturaId], references: [id], onDelete: Cascade)

  // Relazione Accessori (Molti-a-molti implicita: una prenotazione può avere più accessori)
  accessori       Accessorio[]
}

model Accessorio {
  id           Int            @id @default(autoincrement())
  nome         String
  prezzo       Float          @default(0.0) // Task 1: Listino prezzi accessori
  prenotazioni Prenotazione[]
}

model Assicurazione {
  id           Int            @id @default(autoincrement())
  tipo         String         // Es: "Kasko", "Base"
  dettagli     String
  prezzo       Float          @default(0.0) // Task 1: Listino prezzi assicurazioni
  prenotazioni Prenotazione[]
}