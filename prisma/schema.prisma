generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["new"]
}

// ==========================================
// ENUMS
// ==========================================

enum Alimentazione {
  MUSCOLARE
  ELETTRICA
  @@schema("new")
}

enum StatoPrenotazione {
  PENDING
  PICKED_UP
  RETURNED
  LATE
  DAMAGED
  @@schema("new")
}

// ==========================================
// UTENTI E AUTENTICAZIONE
// ==========================================

model Role {
  role  String @id
  users User[]
  @@schema("new")
}

model User {
  id                Int            @id @default(autoincrement())
  firstName         String
  lastName          String
  email             String         @unique
  password          String
  verified          Boolean        @default(false)
  verificationToken String?
  roleName          String
  role              Role           @relation(fields: [roleName], references: [role])
  notifiche         Notifica[]
  prenotazioni      Prenotazione[]
  refreshTokens     RefreshToken[]
  @@schema("new")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@schema("new")
}

model Notifica {
  id        Int      @id @default(autoincrement())
  messaggio String
  tipo      String   @default("generica")
  sentAt    DateTime @default(now())
  letto     Boolean  @default(false)
  utenteId  Int
  utente    User     @relation(fields: [utenteId], references: [id])
  @@schema("new")
}

// ==========================================
// PRENOTAZIONI
// ==========================================

model Prenotazione {
  id            Int      @id @default(autoincrement())
  dataCreazione DateTime @default(now())
  dataRitiro    DateTime @db.Date
  oraRitiro     String
  dataConsegna  DateTime
  oraConsegna   String

  stato          StatoPrenotazione @default(PENDING)
  alimentazione  Alimentazione
  note           String?
  noteRiconsegna String?
  danni          String?
  totalePagato   Decimal           @db.Decimal(10, 2)

  utenteId Int
  utente   User @relation(fields: [utenteId], references: [id], onDelete: Cascade)

  biciclettaId Int
  bicicletta   SpecificheBicicletta @relation(fields: [biciclettaId], references: [id], onDelete: Cascade)

  locationId Int
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  coperturaId Int
  copertura   Assicurazione @relation(fields: [coperturaId], references: [id], onDelete: Cascade)

  prenotazioni AccessorioPrenotazione[]
  riparazioni  Riparazione[]
  @@schema("new")
}

model Accessorio {
  id           Int                      @id @default(autoincrement())
  nome         String
  prezzo       Float                    @default(0.0)
  prenotazioni AccessorioPrenotazione[]
  @@schema("new")
}

model AccessorioPrenotazione {
  id             Int          @id @default(autoincrement())
  accessorioId   Int
  prenotazioneId Int
  accessorio     Accessorio   @relation(fields: [accessorioId], references: [id], onDelete: Cascade)
  prenotazione   Prenotazione @relation(fields: [prenotazioneId], references: [id], onDelete: Cascade)
  @@schema("new")
}

model Assicurazione {
  id           Int            @id @default(autoincrement())
  tipo         String
  dettagli     String
  prezzo       Decimal        @default(0.0)
  prenotazioni Prenotazione[]
  @@schema("new")
}

// ==========================================
// LOCATION
// ==========================================

model Location {
  id        Int    @id @default(autoincrement())
  nome      String
  indirizzo String

  biciclette   BiciclettaLocation[]
  prenotazioni Prenotazione[]
  @@schema("new")
}

model BiciclettaLocation {
  id                   Int    @id @default(autoincrement())
  locationId           Int
  biciclettaSpecificId Int
  quantitaMuscolare    Int    @default(0)
  quantitaElettrica    Int    @default(0)

  location           Location             @relation(fields: [locationId], references: [id], onDelete: Cascade)
  biciclettaSpecific SpecificheBicicletta @relation(fields: [biciclettaSpecificId], references: [id], onDelete: Cascade)
  riparazioni        Riparazione[]
  @@unique([locationId, biciclettaSpecificId])
  @@schema("new")
}

// ==========================================
// RIPARAZIONI
// ==========================================

model Riparazione {
  id                   Int       @id @default(autoincrement())
  biciclettaLocationId Int
  prenotazioneId       Int?
  motivo               String
  costo                Decimal?  @db.Decimal(10, 2)
  aperta               Boolean   @default(true)
  dataInizio           DateTime  @default(now())
  dataFine             DateTime?

  biciclettaLocation BiciclettaLocation @relation(fields: [biciclettaLocationId], references: [id], onDelete: Cascade)
  prenotazione       Prenotazione?      @relation(fields: [prenotazioneId], references: [id])
  @@schema("new")
}

// ==========================================
// BICICLETTE E SPECIFICHE
// ==========================================

enum TipologiaBicicletta {
  CITY
  MOUNTAIN
  GRAVEL
  ROAD
  @@schema("new")
}

model Bicicletta {
  id        Int                     @id @default(autoincrement())
  nome      String
  tipologia TipologiaBicicletta
  specifics SpecificheBicicletta[]
  @@schema("new")
}

model SpecificheBicicletta {
  id                  Int                  @id @default(autoincrement())
  size                String
  prezzoGiornata      Decimal              @db.Decimal(10, 2)
  prezzoMezzaGiornata Decimal              @db.Decimal(10, 2)
  altezzaMin          Int?
  altezzaMax          Int?
  biciclettaId        Int
  bicicletta          Bicicletta           @relation(fields: [biciclettaId], references: [id])
  prenotazione        Prenotazione[]
  location            BiciclettaLocation[]
  @@unique([biciclettaId, size])
  @@schema("new")
}