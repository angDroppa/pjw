// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["other"]
}

model Role {
  role  String @id
  users User[]

  @@schema("other")
}

model User {
  id        Int    @id @default(autoincrement())
  firstName String
  lastName  String
  email     String @unique
  password  String
  role      Role   @relation(fields: [roleName], references: [role])
  roleName  String @default("ADMIN")

  delivery      Delivery[]
  refreshTokens RefreshToken[]

  @@schema("other")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("other")
}

model Customer {
  id          Int    @id @default(autoincrement())
  firstName   String
  lastName    String
  address     String
  number      Int
  city        String
  province    String
  phoneNumber String
  email       String
  notes       String

  delivery Delivery[]

  @@schema("other")
}

model Delivery {
  id Int @id @default(autoincrement())

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  stateId String
  state   DeliveryState @relation(fields: [stateId], references: [id], onDelete: Cascade)

  pickupDate DateTime
  deliveryDate DateTime

  deliveryKey String

  @@schema("other")
}

model DeliveryState {
  id String @id

  delivery Delivery[]

  @@schema("other")
}
