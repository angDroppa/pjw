generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Role {
  role  String @id
  users User[]
}

model User {
  id        Int    @id @default(autoincrement())
  firstName String
  lastName  String
  email     String @unique
  password  String

  role     Role   @relation(fields: [roleName], references: [role])
  roleName String

  refreshTokens RefreshToken[]
  prenotazioni  Prenotazione[]
  notifiche     Notifica[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bicicletta {
  id          Int       @id @default(autoincrement())
  modelloId   Int
  modello     Modello   @relation(fields: [modelloId], references: [id])

  tipologiaId Int
  tipologia   Tipologia @relation(fields: [tipologiaId], references: [id])

  dimesione Dimensione[]

  prenotazioni Prenotazione[]
}

model Modello {
  id          Int          @id @default(autoincrement())
  nome        String
  biciclette Bicicletta[]
}

model Tipologia {
  id          Int          @id @default(autoincrement())
  nome        String
  biciclette Bicicletta[]
}

model Prenotazione {
  id              Int       @id @default(autoincrement())
  dataRitiro      DateTime
  dataOreConsegna DateTime
  dataPickUp      DateTime

  utenteId        Int
  utente          User       @relation(fields: [utenteId], references: [id], onDelete: Cascade)

  biciclettaId    Int
  bicicletta      Bicicletta @relation(fields: [biciclettaId], references: [id], onDelete: Cascade)

  locationId      Int
  location        Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)

  // Spostati qui per gestire la configurazione dinamica dell'ordine (Product Card)
  coperturaId     Int
  copertura       Assicurazione @relation(fields: [coperturaId], references: [id], onDelete: Cascade)

  accessori       Accessorio[]  // Relazione molti-a-molti implicita sulla prenotazione
}

model Accessorio {
  id           Int            @id @default(autoincrement())
  nome         String
  prenotazioni Prenotazione[] // Legato alle prenotazioni, non più alle biciclette
}

model Assicurazione {
  id           Int            @id @default(autoincrement())
  tipo         String
  dettagli     String
  prenotazioni Prenotazione[] // Legato alle prenotazioni, non più alle biciclette
}

model Location {
  id           Int            @id @default(autoincrement())
  nome         String
  indirizzo    String
  prenotazioni Prenotazione[]
}

model Notifica {
  id        Int    @id @default(autoincrement())
  messaggio String
  utenteId  Int
  utente    User   @relation(fields: [utenteId], references: [id])
}

model Dimensione {
  id Int          @id @default(autoincrement())
  biciclettaId Int  
  bicicletta      Bicicletta @relation(fields: [biciclettaId], references: [id], onDelete: Cascade)        

  taglia String
  numeroBiciclette Int
}